# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  # Detect if running in nested virtualization
  require "open3"

  def cmd_output(cmd)
    stdout, status = Open3.capture2(cmd)
    status.success? ? stdout.strip : ""
  rescue
    ""
  end

  def file_contains_any?(path, needles)
    return false unless File.exist?(path)
    content = File.read(path).downcase
    needles.any? { |n| content.include?(n) }
  rescue
    false
  end

  virt_type = cmd_output("systemd-detect-virt")
  virtual_markers = %w[virtualbox oracle kvm qemu vmware xen hyper-v]

  is_nested_virtualbox =
    virtual_markers.include?(virt_type.downcase) ||
    file_contains_any?("/sys/class/dmi/id/product_name", %w[virtualbox kvm qemu vmware]) ||
    file_contains_any?("/sys/class/dmi/id/sys_vendor", %w[innotek oracle qemu vmware])

  # Optional explicit override from .env for NESTED_MODE (true/false)
  env_file_path_early = File.expand_path(".env", __dir__)
  nested_ip_override = nil
  public_network_bridge_early = nil
  if File.exist?(env_file_path_early)
    File.foreach(env_file_path_early) do |line|
      next if line.strip.empty? || line.lstrip.start_with?("#")
      key, value = line.split("=", 2)
      next if key.nil? || value.nil?
      parsed_value = value.strip.gsub(/\A["']|["']\z/, "")
      if key.strip == "NESTED_MODE"
        is_nested_virtualbox = parsed_value.downcase == "true"
      elsif key.strip == "PRIVATE_NETWORK_IP_NESTED"
        nested_ip_override = parsed_value
      elsif key.strip == "PUBLIC_NETWORK_BRIDGE"
        public_network_bridge_early = parsed_value
      end
    end
  end

  # Some nested hosts do not expose reliable virtualization facts.
  # Bridge names like enp0s3/eth0 are typical inside nested VMs.
  nested_bridge_names = %w[enp0s3 eth0]
  bridge_looks_nested = nested_bridge_names.include?(public_network_bridge_early.to_s.strip)
  is_nested_virtualbox = true if bridge_looks_nested

  # Configure private network based on nesting detection
  # VirtualBox often restricts host-only ranges to 192.168.56.0/21.
  # Pick the first subnet that is not already routed on the current host.
  nested_network_candidates = [
    ["192.168.60.0/24", "192.168.60.10"],
    ["192.168.61.0/24", "192.168.61.10"],
    ["192.168.62.0/24", "192.168.62.10"],
    ["192.168.63.0/24", "192.168.63.10"],
    ["192.168.59.0/24", "192.168.59.10"],
    ["192.168.58.0/24", "192.168.58.10"],
    ["192.168.57.0/24", "192.168.57.10"]
  ]
  current_routes = cmd_output("ip -o -4 route show")
  used_cidrs = current_routes.lines.map { |line| line.split.first }
  auto_nested_ip = nested_network_candidates.find { |cidr, _ip| !used_cidrs.include?(cidr) }&.last || "192.168.60.10"
  private_network_ip_nested = nested_ip_override.to_s.strip.empty? ? auto_nested_ip : nested_ip_override

  network_mode = is_nested_virtualbox ? "nested-static (#{private_network_ip_nested})" : "regular-dhcp"
  puts "[Vagrant] Network mode: #{network_mode}"

  if is_nested_virtualbox
    config.vm.network "private_network", ip: private_network_ip_nested
  else
    config.vm.network "private_network", type: "dhcp"
  end

  host_port_22 = 2222
  host_port_22_string = "2222"
  host_port_443 = 8484
  host_port_8080 = 8282
  host_port_8081 = 8383
  host_port_9001 = 9004
  host_port_8983 = 9191
  host_port_8890 = 8890
  host_port_8585 = 8585
  host_port_8443 = 65535

  env_file_path = File.expand_path(".env", __dir__)
  env_values = {}

  if File.exist?(env_file_path)
    File.foreach(env_file_path) do |line|
      next if line.strip.empty? || line.lstrip.start_with?("#")

      key, value = line.split("=", 2)
      next if key.nil? || value.nil?

      parsed_value = value.strip.gsub(/\A["']|["']\z/, "")
      next if parsed_value.empty?

      env_values[key.strip] = parsed_value
    end
  end

  public_network_bridge = env_values["PUBLIC_NETWORK_BRIDGE"]
  host_user_name = env_values["HOST_USER_NAME"] || "root"
  vm_box = env_values["VM_BOX"]
  vm_disk_size = env_values["VM_DISK_SIZE"] || "100GB"
  vm_memory = (env_values["VM_MEMORY"] || "1200").to_i
  vm_cpus = (env_values["VM_CPUS"] || "4").to_i

  vm_memory = 1200 if vm_memory <= 0
  vm_cpus = 1 if vm_cpus <= 0
  vm_cpus = 1 if is_nested_virtualbox


  if !is_nested_virtualbox && public_network_bridge.to_s.strip.empty?
    abort("ERROR: PUBLIC_NETWORK_BRIDGE is empty. Set it in #{env_file_path} (example: PUBLIC_NETWORK_BRIDGE=enp2s0).")
  end

  if vm_box.to_s.strip.empty?
    abort("ERROR: VM_BOX is empty. Set it in #{env_file_path} (example: VM_BOX=ubuntu/jammy64).")
  end

  config.trigger.after :up do |trigger|
    trigger.name = "ssh-keygen"
    trigger.run = {inline: 'ssh-keygen -f "/home/' << host_user_name << '/.ssh/known_hosts" -R "[127.0.0.1]:' << host_port_22_string << '"'}  
  end

  config.vm.define "default", autostart: false do |default|
    if Vagrant.has_plugin? "vagrant-vbguest"
      config.vbguest.no_install  = true
    end

    # Consider using: cloud-image/ubuntu-24.04
    default.vm.box = vm_box
    # @TODO: make the disk size configurable:
    default.disksize.size = vm_disk_size
    # SSH:
    default.vm.network "forwarded_port", guest: 22, host: host_port_22
    # Apache from guest in SSL to any IP in host for allowing redirection:
    default.vm.network "forwarded_port", guest: 443, host: host_port_443, host_ip: "0.0.0.0"
    # Docker from guest in SSL to any IP in host for allowing redirection:
    default.vm.network "forwarded_port", guest: 8080, host: host_port_8080, host_ip: "0.0.0.0"
    default.vm.network "forwarded_port", guest: 8081, host: host_port_8081, host_ip: "0.0.0.0"
    # Gitlab by default stays at 8443:
    default.vm.network "forwarded_port", guest: 8443, host: host_port_8443, host_ip: "0.0.0.0"
    # Redirection for Virtuoso:
    default.vm.network "forwarded_port", guest: 8890, host: host_port_8890, host_ip: "0.0.0.0"
    # Redirection for PHPMYADMIN from docker:
    default.vm.network "forwarded_port", guest: 8585, host: host_port_8585, host_ip: "0.0.0.0"
    # Redirection for xdebug:
    default.vm.network "forwarded_port", guest: 9003, host: host_port_9001, host_ip: "0.0.0.0"
    # Solr by default stays at 8983:
    default.vm.network "forwarded_port", guest: 8983, host: host_port_8983, host_ip: "0.0.0.0"
    if is_nested_virtualbox
      puts "[Vagrant] Nested mode: skipping public_network bridge"
    else
      default.vm.network "public_network", bridge: public_network_bridge, ip: "192.168.0.222"
    end
    default.vm.synced_folder "data", "/vagrant_data"
    default.vm.provider "virtualbox" do |vb|
      # Dont display the VirtualBox GUI when booting the machine
      vb.gui = false
      # Customize the amount of memory on the VM:
      vb.memory = vm_memory
      vb.cpus = vm_cpus
      vb.customize ['modifyvm', :id, '--graphicscontroller', 'vmsvga']

      if is_nested_virtualbox
        # Nested environments can fail to boot when forcing low-level HW virt flags.
        vb.customize ['modifyvm', :id, '--paravirtprovider', 'default']
      else
        vb.customize ['modifyvm', :id, '--hwvirtex', 'on']
        vb.customize ['modifyvm', :id, '--nested-hw-virt', 'on']
        vb.customize ['modifyvm', :id, '--nestedpaging', 'on']
        vb.customize ['modifyvm', :id, '--largepages', 'on']
        vb.customize ['modifyvm', :id, '--vtxux', 'on']
        vb.customize ['modifyvm', :id, '--vtxvpid', 'on']
        vb.customize ['modifyvm', :id, '--paravirtprovider', 'kvm']
      end
    end
    ssh_pub_key = File.readlines("#{Dir.home}/.ssh/id_rsa.pub").first.strip
    default.vm.provision 'shell', inline: "echo #{ssh_pub_key} >> /home/vagrant/.ssh/authorized_keys", privileged: false
    # Configure swap memory via shell provisioner
    config.vm.provision "shell", inline: <<-SHELL
      # Create a 1GB swap file (adjust count for desired size)
      sudo dd if=/dev/zero of=/swapfile bs=1M count=1024 status=progress
      sudo chmod 600 /swapfile
      sudo mkswap /swapfile
      # Make swap permanent (persist across reboots)
      echo '/swapfile none swap sw 0 0' | sudo tee -a /etc/fstab
    SHELL
  end
end
